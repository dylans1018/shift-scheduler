{{define "base"}}
<!doctype html>
<html lang='en'>
    <head>
        <meta charset='utf-8'>
        <title>Home - Shift Scheduler</title>
        <!-- Link to the CSS stylesheet and favicon -->
        <link rel='stylesheet' href='/static/css/main.css'>
        <link rel='shortcut icon' href='/static/img/favicon.ico' type='image/x-icon'> 
        
        <script src="/static/htmx.min.js"></script>
    </head>
    <body>
        <header>
            <h1><a href='/'>Shift Scheduler</a></h1>

            {{if .Role}}
                <div class="user-profile">
                    <span>Logged in as: <strong>{{.Role}}</strong></span>
                    <button hx-post="/logout" style="margin-left: 10px;">Log Out</button>
                </div>
            {{end}}
        </header>

        <main>
            {{template "content" .}}
        </main>

        <footer>Powered by <a href='https://mendix.byu.edu/'>BYU LowCode => Go</a></footer>
    </body>
</html>
{{end}}